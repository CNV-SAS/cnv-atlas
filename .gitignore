# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Excepcion: la plantilla de variables SI se versiona (no lleva secretos).
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Atlas: material de referencia (HTMLs de Gildardo, XLSX de muestra de Biody).
# Pesado y posible portador de PII; se consulta local, no se versiona.
/reference/

# Snippets generados por Supabase Studio en local; no son fuente del proyecto.
/supabase/snippets/
