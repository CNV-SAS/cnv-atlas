# Plantilla de variables de entorno de Atlas.
# Fuente de verdad: docs/DEPLOY.md ("Variables de entorno").
#
# Esta plantilla NO lleva valores: copiala a .env.local y rellena ahi tus keys.
# .env.local esta gitignorado y nunca se comitea. Los secretos se comparten por
# el gestor de secretos (Bitwarden), jamas por chat ni email.
#
# Regla critica: nada sensible lleva prefijo NEXT_PUBLIC_. Las variables con ese
# prefijo se exponen al navegador por diseno; el resto es solo de servidor.

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # solo server, bypassa RLS, llave maestra
DATABASE_URL=                       # solo server, Drizzle (migraciones + queries)

# ===== IA (Groq / Gemini) =====
GROQ_API_KEY=                       # solo server
GROQ_MODEL=
GEMINI_API_KEY=                     # solo server
GEMINI_MODEL=

# ===== Email (Resend) =====
RESEND_API_KEY=                     # solo server
EMAIL_FROM=
EMAIL_REPLY_TO=

# ===== Pagos (Wompi / Alegra) =====
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=       # publico por diseno (widget de checkout)
WOMPI_PRIVATE_KEY=                  # solo server
WOMPI_EVENTS_SECRET=                # solo server, valida firma HMAC de webhooks
WOMPI_INTEGRITY_SECRET=             # solo server, firma de integridad del checkout
ALEGRA_EMAIL=                       # solo server
ALEGRA_API_KEY=                     # solo server

# ===== Rate limiting (Upstash Redis) =====
UPSTASH_REDIS_REST_URL=             # solo server
UPSTASH_REDIS_REST_TOKEN=           # solo server

# ===== Observabilidad (Sentry) =====
NEXT_PUBLIC_SENTRY_DSN=             # publico por diseno
SENTRY_AUTH_TOKEN=                  # solo server / build (subida de sourcemaps)

# ===== App =====
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=
# NODE_ENV lo gestiona Next automaticamente; normalmente no se fija a mano.
